# さいたま市立図書館 ログイン情報
# このファイルを .env にコピーして入力してください
# ※ .env は絶対に Git にコミットしないでください

LIBRARY_CARD_NUMBER=あなたの利用者番号（カード裏面）
LIBRARY_PASSWORD=あなたのパスワード（4〜8桁）

# 予約リストのパス（デフォルト: ../reserve-list.json）
RESERVE_LIST_PATH=../reserve-list.json

# ブラウザを画面表示するか（true=表示 false=バックグラウンド）
HEADLESS=false

# 予約時の受取館（例: さいたま市立中央図書館）
PICKUP_LIBRARY=
